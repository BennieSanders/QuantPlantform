QUANT_PLATFORM_ENV=development
QUANT_PLATFORM_ALLOW_DEV_AUTH_FALLBACK=false
QUANT_PLATFORM_AUTH_SECRET=replace-with-a-random-secret

# Optional external AI providers. Keep real keys in backend/.env.local.
QUANT_PLATFORM_GEMINI_API_KEY=
QUANT_PLATFORM_GEMINI_MODEL=gemini-2.5-flash
QUANT_PLATFORM_GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.5-flash
QUANT_PLATFORM_MARKET_DATA_BASE_URL=https://api.binance.com
QUANT_PLATFORM_MARKET_DATA_FALLBACK_URLS=https://data-api.binance.vision
QUANT_PLATFORM_MARKET_DATA_TIMEOUT_SECONDS=20
# Optional, only needed when the external market data provider must go through a local proxy.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
QUANT_PLATFORM_OPENAI_API_KEY=
QUANT_PLATFORM_OPENAI_MODEL=gpt-5.5
